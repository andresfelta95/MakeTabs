# Spotify Developer App credentials
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:8000/auth/callback

# Session secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET_KEY=change_me_generate_a_random_value

# Token encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=change_me_generate_a_fernet_key

# Database (SQLite for local, swap to postgresql+asyncpg://... for production)
DATABASE_URL=sqlite+aiosqlite:///./maketabs.db

# Frontend URL (for redirects after OAuth)
FRONTEND_URL=http://localhost:5173

# Environment
ENVIRONMENT=development
